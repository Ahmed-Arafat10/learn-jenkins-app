{
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "family": "learn-jenkins-app-task-definition-prod",
    "containerDefinitions": [
        {
            "name": "Learn-Jenkins-App",
            "image": "508261693782.dkr.ecr.us-east-1.amazonaws.com/practice-jenkins-ecs-ecr-app:1.0.24",
            "essential": true,
            "portMappings": [
                {
                    "name": "nginx-80-tcp",
                    "containerPort": 80,
                    "hostPort": 80,
                    "protocol": "tcp",
                    "appProtocol": "http"
                }
            ]
        }
    ],
    "volumes": [],
    "networkMode": "awsvpc",
    "memory": "512",
    "cpu": "256",
    "executionRoleArn": "arn:aws:iam::508261693782:role/ecsTaskExecutionRole"
}